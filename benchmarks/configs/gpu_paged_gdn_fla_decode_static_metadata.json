{
  "name": "gpu_paged_gdn_fla_decode_static_metadata",
  "description": "Strict block-dot FLA prefill route plus packed prefill/decode projections, BF16 model compute, BF16 full-attention KV cache, BF16-QKV conv-fused Triton FLA GDN decode, canonical packed MLP gate/up weights, no-Triton-GEMM XLA lowering, and static decode metadata reuse.",
  "benchmark_script": "benchmarks/benchmark_jax_server_trace.py",
  "reference_json": "results/qwen08_jax_server_trace_hetero8_64_512x32_gdn_chunk32_default_repeat.json",
  "vllm_reference_json": "",
  "workload_reference_jsons": {
    "hetero8": "results/qwen08_jax_server_trace_hetero8_64_512x32_gdn_chunk32_default_repeat.json",
    "long_prefill_512_2048": "results/gpu_matrix_runs/20260526_104818/long_prefill_512_2048_gpu_paged_default_repeat1.json",
    "decode_heavy_128x128": "results/gpu_matrix_runs/20260530_123105/references/jax_default_decode_heavy_128x128.json"
  },
  "workload_vllm_reference_jsons": {
    "hetero8": "results/qwen08_vllm_async_delta_baseline_hetero8_64_512x32.json",
    "long_prefill_512_2048": "results/gpu_matrix_runs/20260526_104818/references/vllm_long_prefill_512_2048.json",
    "decode_heavy_128x128": "results/gpu_matrix_runs/20260530_073500/references/vllm_decode_heavy_128x128.json"
  },
  "allow_live_vllm_if_reference_missing": false,
  "allow_live_jax_default_if_reference_missing": true,
  "runtime": {
    "platform": "cuda",
    "xla": {
      "flags": "--xla_gpu_autotune_level=4 --xla_gpu_enable_triton_gemm=false"
    },
    "fastpaths": {
      "greedy_token": true,
      "materialize_tied_lm_head": true,
      "compact_prefill_in_proj_qkv": true,
      "compact_prefill_gdn_z": true,
      "compact_prefill_full_attn_proj": true,
      "compact_prefill_mlp": true,
      "compact_prefill_token_count_mode": "bucket",
      "device_token_carry": true,
      "static_decode_metadata": true,
      "lm_head_decode_act_dtype": "bf16",
      "decode_proj_act_dtype": "bf16",
      "decode_padded_gemm": true,
      "decode_padded_gemm_gate_up": true,
      "decode_padded_gemm_rows": 8,
      "decode_padded_gemm_max_out_dim": 8192
    }
  },
  "kernels": {
    "backend": "pure_jax",
    "allow_local_cuda_probes": false,
    "full_attention": {
      "kv_cache_dtype": "bf16"
    },
    "gdn": {
      "disable_fallbacks": true,
      "prefill_post_conv_impl": "triton_fla_padded",
      "prefill_block_dot": true,
      "packed_decode": {
        "impl": "triton_fla_conv_raw_gates",
        "qkv_dtype": "bf16"
      }
    }
  },
  "args": {
    "model": "Qwen/Qwen3.5-0.8B",
    "backend": "gpu",
    "dtype": "bfloat16",
    "weight_dtype": "bfloat16",
    "jax_execution": "jit",
    "input_lens": "64,128,192,256,320,384,448,512",
    "output_len": 32,
    "prompt_suite": "mixed",
    "num_speculative_tokens": 0,
    "max_kv_cache_mb": 3072,
    "num_kvcache_blocks": 256,
    "max_num_seqs": 8,
    "max_num_batched_tokens": 4096,
    "prefill_buckets": "64,128,256,384,512",
    "prefill_token_buckets": "64,128,256,512,1024,2048,4096",
    "prefill_layout": "packed",
    "batch_size_buckets": "1,2,4,8",
    "max_blocks_per_seq": 40,
    "greedy_token_fastpath": true,
    "device_token_carry": true,
    "static_decode_metadata": true,
    "static_decode_seq_lens_carry": false,
    "top_k": 5,
    "warmup": true,
    "warmup_mode": "generic",
    "fail_on_jit_cache_growth": true,
    "profile": false
  }
}
