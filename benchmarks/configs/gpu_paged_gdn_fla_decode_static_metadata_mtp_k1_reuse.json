{
  "name": "gpu_paged_gdn_fla_decode_static_metadata_mtp_k1_reuse",
  "description": "Diagnostic exact greedy MTP K=1 route over the accepted static-metadata serving path. Intended to exercise full B>1 rows through the decode-reuse verifier rather than the heavier K=2 target verifier.",
  "benchmark_script": "benchmarks/benchmark_jax_server_multisuite.py",
  "reference_json": "results/qwen08_jax_server_trace_hetero8_64_512x32_gdn_chunk32_default_repeat.json",
  "vllm_reference_json": "",
  "workload_reference_jsons": {
    "hetero8": "results/qwen08_jax_server_trace_hetero8_64_512x32_gdn_chunk32_default_repeat.json",
    "long_prefill_512_2048": "results/gpu_matrix_runs/20260526_104818/long_prefill_512_2048_gpu_paged_default_repeat1.json",
    "decode_heavy_128x128": "results/gpu_matrix_runs/20260530_123105/references/jax_default_decode_heavy_128x128.json"
  },
  "workload_vllm_reference_jsons": {
    "hetero8": "results/qwen08_vllm_async_delta_baseline_hetero8_64_512x32.json",
    "long_prefill_512_2048": "results/gpu_matrix_runs/20260526_104818/references/vllm_long_prefill_512_2048.json",
    "decode_heavy_128x128": "results/gpu_matrix_runs/20260530_073500/references/vllm_decode_heavy_128x128.json"
  },
  "allow_live_vllm_if_reference_missing": false,
  "allow_live_jax_default_if_reference_missing": true,
  "runtime": {
    "platform": "cuda",
    "xla": {
      "flags": "--xla_gpu_autotune_level=4 --xla_gpu_enable_triton_gemm=false"
    },
    "fastpaths": {
      "greedy_token": true,
      "materialize_tied_lm_head": true,
      "compact_prefill_in_proj_qkv": true,
      "compact_prefill_gdn_z": true,
      "compact_prefill_full_attn_proj": true,
      "compact_prefill_mlp": true,
      "compact_prefill_token_count_mode": "bucket",
      "device_token_carry": true,
      "static_decode_metadata": true,
      "resident_decode_metadata": true,
      "trace_token_prefetch": true,
      "lm_head_decode_act_dtype": "bf16",
      "lm_head_topk_impl": "jax",
      "lm_head_greedy_top1_impl": "triton",
      "decode_proj_act_dtype": "bf16",
      "decode_padded_gemm": true,
      "decode_padded_gemm_gate_up": true,
      "decode_padded_gemm_rows": 8,
      "decode_padded_gemm_max_out_dim": 300000
